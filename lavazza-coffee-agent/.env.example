# ─────────────────────────────────────────────
# LLM — Anthropic
# ─────────────────────────────────────────────
# Ottieni su: https://console.anthropic.com
ANTHROPIC_API_KEY=CHANGE-ME-sk-ant-...

# ─────────────────────────────────────────────
# MongoDB Atlas (cloud — già condiviso dal team)
# ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/
MONGODB_DB=lavazza_ifab

# ─────────────────────────────────────────────
# MongoDB Atlas Admin API — Service Account
# Per aggiungere IP alla whitelist senza browser:
#   python scripts/atlas_whitelist_ip.py
# Crea su: Atlas → Org → Access Manager → Applications → Service Accounts
# ─────────────────────────────────────────────
ATLAS_CLIENT_ID=CHANGE-ME
ATLAS_CLIENT_SECRET=CHANGE-ME
ATLAS_PROJECT_ID=CHANGE-ME  # Atlas → Project Settings → Project ID

# ─────────────────────────────────────────────
# Qdrant Cloud
# ─────────────────────────────────────────────
# Questo progetto usa solo Qdrant Cloud. Non configurare localhost.
QDRANT_URL=https://xxx.cloud.qdrant.io
QDRANT_API_KEY=CHANGE-ME

# Opzionale: alias dinamici per source-targeted search del chatbot.
# JSON object: keyword -> {"collection": "...", "source": "..."} oppure ["collection", "source"].
# Usa null per disabilitare un alias default.
# QDRANT_SOURCE_KEYWORDS_JSON={"mia fonte":{"collection":"geo_texts","source":"MY_SOURCE"}}
