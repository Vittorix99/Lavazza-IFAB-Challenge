# ─────────────────────────────────────────────
# n8n runtime
# ─────────────────────────────────────────────
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=Europe/Rome
TZ=Europe/Rome
N8N_RUNNERS_ENABLED=true
N8N_ENCRYPTION_KEY=CHANGE-ME-run-openssl-rand-hex-32
N8N_SECURE_COOKIE=false
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# ─────────────────────────────────────────────
# API keys usate nei nodi n8n
# ─────────────────────────────────────────────
# Gratuita: https://firms.modaps.eosdis.nasa.gov/api/area/
NASA_FIRMS_KEY=CHANGE-ME

# Gratuita: https://api.data.gov/signup/
USDA_API_KEY=CHANGE-ME

# Gratuita: https://aisstream.io
AISSTREAM_API_KEY=CHANGE-ME

# Account FAOSTAT: https://www.fao.org/faostat
FAOSTAT_USERNAME=CHANGE-ME-your-email
FAOSTAT_PASSWORD=CHANGE-ME

# ─────────────────────────────────────────────
# MongoDB (container locale)
# ─────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=lavazza_root
MONGO_INITDB_ROOT_PASSWORD=CHANGE-ME-root-password
MONGO_APP_DATABASE=lavazza_ifab
MONGO_APP_USERNAME=lavazza_app
MONGO_APP_PASSWORD=CHANGE-ME-app-password
